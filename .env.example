# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Lyvee.link"
NODE_ENV=development

# Supabase — public browser/server anon client
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase — server-only admin access
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Stripe platform account
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Stripe Connect
STRIPE_CONNECT_CLIENT_ID="ca_xxx"

# Platform fee in basis points: 490 = 4.9%
LYVEE_APPLICATION_FEE_BPS=490

# Optional: Seller notifications
RESEND_API_KEY="re_xxx"
NOTIFICATION_FROM_EMAIL="Lyvee.link <sales@lyvee.link>"

# Optional: basic analytics / abuse protection
IP_HASH_SECRET="replace-with-long-random-string"
